{
  "name": "obsidian-theme-gfm",
  "type": "module",
  "version": "1.0.13",
  "private": true,
  "packageManager": "pnpm@10.33.4",
  "description": "GitHub Flavored Markdown Theme for Obsidian",
  "author": "Frankie <1426203851@qq.com>",
  "license": "MIT",
  "homepage": "https://community.obsidian.md/themes/github-flavored-markdown-theme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/obsidian-theme-gfm.git"
  },
  "bugs": {
    "url": "https://github.com/tofrankie/obsidian-theme-gfm/issues",
    "email": "1426203851@qq.com"
  },
  "scripts": {
    "update-version": "node scripts/update-version.js",
    "lint": "run-s lint:eslint lint:prettier lint:stylelint",
    "lint:eslint": "eslint . --fix",
    "lint:prettier": "prettier . --write --log-level silent",
    "lint:stylelint": "stylelint '**/*.css' --fix",
    "prepare": "simple-git-hooks"
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@tofrankie/commitlint": "^0.0.6",
    "@tofrankie/eslint": "^0.5.0",
    "@tofrankie/prettier": "^0.2.0",
    "@tofrankie/stylelint": "^0.3.1",
    "eslint": "^10.7.0",
    "github-markdown-css": "^5.9.0",
    "npm-run-all2": "^9.0.2",
    "prettier": "^3.9.5",
    "simple-git-hooks": "^2.13.1",
    "stylelint": "^17.14.0"
  },
  "simple-git-hooks": {
    "pre-commit": "pnpm lint",
    "commit-msg": "pnpm commitlint --edit $1"
  }
}
