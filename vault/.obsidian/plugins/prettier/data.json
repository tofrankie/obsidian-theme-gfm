{
  "version": 20002,
  "settings": {
    "formatOnSave": true,
    "formatOnFileChange": false,
    "formatCodeBlock": true,
    "removeExtraSpaces": false,
    "addTrailingSpaces": false,
    "languageMappings": {},
    "formatOptions": {
      "printWidth": 100,
      "semi": false,
      "singleQuote": true,
      "arrowParens": "avoid",
      "trailingComma": "es5",
      "htmlWhitespaceSensitivity": "css"
    },
    "ignorePatterns": "**/.git\n**/.svn\n**/.hg\n**/node_modules\n**/.obsidian"
  }
}